{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and preferences",
      "type": "object",
      "properties": {
        "watchlist": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of TMDB movie IDs"
        },
        "email": { "type": "string" },
        "displayName": { "type": "string" }
      },
      "required": ["watchlist"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User specific data"
    }
  }
}
